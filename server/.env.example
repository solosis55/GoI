PORT=4000

# En produccion: export NODE_ENV=production (o lo define tu PaaS).
# NODE_ENV=production

# En Vercel sin esta variable, el servidor usa un secreto automatico (demo). En Node
# propio con NODE_ENV=production (sin VERCEL), sigue siendo obligatoria.
# JWT_SECRET=genera_un_string_largo_y_unico

# Opcional: ruta absoluta al store JSON en runtime (por defecto server/data/store.json;
# en Vercel serverless se usa /tmp salvo que definas otra ruta aqui).
# GOI_STORE_PATH=/ruta/absoluta/store.json
# (legacy) FITSOCIAL_STORE_PATH=/ruta/absoluta/store.json

# Solo desarrollo: si es "true", POST /api/auth/forgot-password devuelve `devResetToken`
# cuando el email existe, para probar el flujo sin servicio de correo. Nunca en produccion.
# AUTH_RESET_RETURN_TOKEN=true
