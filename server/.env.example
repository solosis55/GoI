PORT=4000

# En produccion: export NODE_ENV=production (o lo define tu PaaS).
# NODE_ENV=production

# Obligatorio en produccion antes de usar login/register (emisión del JWT falla si falta).
# JWT_SECRET=genera_un_string_largo_y_unico

# Solo desarrollo: si es "true", POST /api/auth/forgot-password devuelve `devResetToken`
# cuando el email existe, para probar el flujo sin servicio de correo. Nunca en produccion.
# AUTH_RESET_RETURN_TOKEN=true
